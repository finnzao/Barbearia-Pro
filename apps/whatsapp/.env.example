PORT=4000
AUTH_DIR=./data/auth
# Mesmo segredo configurado na API (WHATSAPP_API_TOKEN) — protege /mensagens e o webhook.
WHATSAPP_API_TOKEN=troque_este_segredo_interno
# Para onde o serviço avisa quando a sessão conecta/cai. Vazio = desliga o aviso.
WEBHOOK_URL=http://api:3333/api/publico/whatsapp/status
