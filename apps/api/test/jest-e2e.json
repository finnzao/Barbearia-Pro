{
  "rootDir": ".",
  "roots": ["<rootDir>"],
  "maxWorkers": 1,
  "moduleFileExtensions": ["js", "json", "ts"],
  "testRegex": "\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.json" }]
  },
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/support/jest.setup.ts"],
  "globalSetup": "<rootDir>/support/global-setup.js"
}
