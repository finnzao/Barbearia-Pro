PORT=3333
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://naregua_app:troque_esta_senha@localhost:5432/naregua?schema=public
# Segredos de assinatura: mínimo 32 chars. Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=troque_este_segredo_com_no_minimo_32_chars
# Mercado Pago (PSP, RN-21/23) — modelo marketplace: cada barbearia conecta a própria
# conta via OAuth e o dinheiro cai direto nela. Sem CLIENT_ID/SECRET, Pix usa o mock.
MERCADOPAGO_WEBHOOK_SECRET=troque_este_segredo_webhook_min_32_chars
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_REDIRECT_URI=https://seu-dominio/api/pagamentos/mercadopago/callback
# Chave da cifra (AES-256-GCM) dos tokens OAuth no banco: 64 chars hex.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CIFRA_SEGREDO=troque_gerando_64_hex
# WhatsApp: se vazios, o OTP só vai pro log (dev/testes). Setados, envia pelo container.
WHATSAPP_API_URL=http://whatsapp:4000
WHATSAPP_API_TOKEN=troque_este_segredo_interno
# Worker de notificações (lembrete/confirmação/cancelamento). Opcionais, com defaults.
# NOTIF_WORKER=off            # desliga o worker
# NOTIF_INTERVALO_MS=120000   # de quanto em quanto drena a fila
# LEMBRETE_ANTECEDENCIA_H=24  # quantas horas antes manda o lembrete
# SILENCIO_INICIO_H=8         # lembrete só sai a partir desta hora (fuso da barbearia)
# SILENCIO_FIM_H=21           # ...e até esta hora
