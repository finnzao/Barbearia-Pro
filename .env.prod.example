# Copie para .env na raiz da VPS. O docker compose lê estas variáveis.
# (Os segredos da API ficam em apps/api/.env — ver DEPLOY.md.)

# Senha do Postgres do container (use algo forte).
POSTGRES_PASSWORD=troque_por_uma_senha_forte

# Domínios reais (DNS apontando pra VPS). O Caddy emite o HTTPS deles.
DOMAIN_APP=app.seudominio.com.br
DOMAIN_API=api.seudominio.com.br

# Segredo compartilhado entre a API e o container do WhatsApp: é o mesmo valor
# nos dois lados, por isso mora aqui e não no .env de cada app. Sem ele, o envio
# de código/lembrete é recusado com 401 e o login por OTP não funciona.
# Gere com: openssl rand -hex 32
WHATSAPP_API_TOKEN=troque_por_um_segredo_forte
